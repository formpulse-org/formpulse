# FormPulse Environment Configuration
# Copy this file to .env and fill in your values

# === Backend (.env goes inside /backend/) ===
GROQ_API_KEY=your_groq_api_key_here

# Supabase PostgreSQL Connection (leave blank for SQLite fallback)
SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase JWT Secret (for backend token validation)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Supabase Storage Configuration (for backend file uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Picky Assist WhatsApp Gateway Integration
PICKY_ASSIST_TOKEN=your_picky_assist_token_here
PICKY_ASSIST_APP_ID=1


# === Frontend (.env goes inside /frontend/) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# FormPulse Backend Environment Configurations
# Generate a free permanent API Key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Supabase PostgreSQL (leave blank for SQLite fallback)
SUPABASE_DATABASE_URL=
SUPABASE_JWT_SECRET=

# Supabase Storage Configuration (for file uploads)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Picky Assist WhatsApp Gateway Integration
PICKY_ASSIST_TOKEN=
PICKY_ASSIST_APP_ID=1

